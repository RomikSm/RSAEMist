# Copy to `.env.local` and adjust if needed.
# Backend base URL used by the Vite dev proxy for the `/api` prefix.
VITE_BACKEND_URL=http://localhost:8080

# Base path of the API; used by the frontend HTTP client.
#
# Dev (Vite proxy):  keep `/api/v1` — the dev server proxies `/api` to
#                    VITE_BACKEND_URL, so cookies stay same-origin.
# Prod (e.g. Vercel): set to the FULL backend URL, e.g.
#                    https://sentinel.adammudrak.pp.ua/api/v1
# Must match the Spring Boot controllers under `@RequestMapping("/api/v1/...")`.
VITE_API_BASE_URL=/api/v1
